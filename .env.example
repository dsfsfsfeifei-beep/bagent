# LLM (OpenAI-compatible). Local Ollama exposes /v1 on 11434.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3.6:35b

# cloud-longsys-srm 后端根 URL（不要带 /supplier 这种业务前缀）
SRM_BASE_URL=http://localhost:8081

# 默认请求超时
HTTP_TIMEOUT=15

# SQLite checkpoint path (per-user memory persistence)
CHECKPOINT_DB=./checkpoints.sqlite
